.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/
.tox/
.nox/

# Linter / type caches
.mypy_cache/
.ruff_cache/
.pytype/

# Editors
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# === Secrets (security/gitignore-env-2026-05-09) ===
